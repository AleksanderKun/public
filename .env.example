# Environment variables for Polish Crypto Tax Calculator
# Copy this file to .env and fill in your values

# DBT Configuration
DBT_PROFILES_DIR=./dbt

# NBP API Configuration (optional - defaults in config)
# NBP_BASE_URL=https://api.nbp.pl/api/exchangerates/rates
# NBP_TABLE=A

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Data Directories (optional - defaults in config)
# RAW_DATA_DIR=data/raw
# PROCESSED_DATA_DIR=data/processed
# EXTERNAL_DATA_DIR=data/external

# Tax Year (optional - defaults in config)
# TAX_YEAR=2026
